# Copy this file to `.tmp/control-plane.env` and fill all values explicitly.

# control-plane now runs in container, so API is typically reached through Traefik.
CONTROL_PLANE_PORT=18090
CONTROL_PLANE_API_BASE_URL=http://127.0.0.1:8080/control-plane

# Keep host URL for local tooling; container runtime auto-resolves this to internal service DNS.
TRAEFIK_DASHBOARD_API_URL=http://127.0.0.1:8080
TRAEFIK_MAX_WAIT_SECONDS=30
TRAEFIK_POLL_INTERVAL_SECONDS=1

# For tenant-creation verification, use whoami so route interaction is easy to observe.
PLATFORM_IMAGE_TAG=traefik/whoami:v1.10.2
PLATFORM_SERVICE_PORT=80

PLATFORM_OPENAI_API_BASE=https://api.openai.com/v1
PLATFORM_OPENAI_API_KEY=replace-with-platform-key
PLATFORM_LOG_LEVEL=INFO

# key provider selection: skeleton | litellm
TENANT_KEY_PROVIDER=skeleton

# when TENANT_KEY_PROVIDER=skeleton
TENANT_KEY_PREFIX=vk_tenant_
TENANT_KEY_ENTROPY_BYTES=24

# when TENANT_KEY_PROVIDER=litellm
# Keep host URL for local tooling; container runtime auto-resolves this to internal service DNS.
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_MASTER_KEY=replace-with-litellm-master-key
LITELLM_MODEL_NAME=gpt-4o-mini
LITELLM_TIMEOUT_SECONDS=10
LITELLM_TOPUP_FX_RATES=USD:1,CNY:0.138000
LITELLM_TOPUP_SYNC_STATE_FILE=/workspace/.tmp/control-plane/litellm-topup-sync-state.json

# LiteLLM consumption auto charge worker
LITELLM_AUTO_CHARGE_ENABLED=false
LITELLM_AUTO_CHARGE_POLL_INTERVAL_SECONDS=5
LITELLM_AUTO_CHARGE_STATE_FILE=/workspace/.tmp/control-plane/litellm-auto-charge-state.json
